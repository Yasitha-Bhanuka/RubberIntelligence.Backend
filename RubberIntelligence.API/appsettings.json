{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "SetViaEnvironmentVariable",
    "Issuer": "RubberIntelligenceBackend",
    "Audience": "RubberIntelligenceApp",
    "ExpiryMinutes": 60
  },
  "MongoDbSettings": {
    "ConnectionString": "SetViaEnvironmentVariable",
    "DatabaseName": "RubberIntelligenceDb"
  },
  "ImageValidation": {
    "MinWidth": 150,
    "MinHeight": 150,
    "BlurThreshold": 10.0,
    "EnableContentVerification": true
  },
  "AlertSettings": {
    "RadiusInKm": 5
  },
  "DiseaseDetectionStrategy": "ONNX",
  "Encryption": {
    "_comment": "DO NOT store real keys here. Inject via env vars: DPP_FIELD_ENCRYPTION_KEY, DPP_FILE_ENCRYPTION_KEY, DPP_BLIND_INDEX_HMAC_KEY. In production, use Azure Key Vault references.",
    "FieldKeyEnvVar": "DPP_FIELD_ENCRYPTION_KEY",
    "FileKeyEnvVar": "DPP_FILE_ENCRYPTION_KEY",
    "HmacKeyEnvVar": "DPP_BLIND_INDEX_HMAC_KEY",
    "CurrentKeyVersion": 1
  }
}