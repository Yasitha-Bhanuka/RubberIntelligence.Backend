{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "SetViaEnvironmentVariable",
    "Issuer": "RubberIntelligenceBackend",
    "Audience": "RubberIntelligenceApp",
    "ExpiryMinutes": 60
  },
  "MongoDbSettings": {
    "ConnectionString": "SetViaEnvironmentVariable",
    "DatabaseName": "RubberIntelligenceDb"
  },
  "ImageValidation": {
    "MinWidth": 224,
    "MinHeight": 224,
    "BlurThreshold": 100.0,
    "EnableContentVerification": true
  },
  "AlertSettings": {
    "RadiusInKm": 5
  }
}